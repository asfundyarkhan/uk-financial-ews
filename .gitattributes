# Git Attributes for UK Financial EWS

# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Jupyter Notebooks
*.ipynb text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
README text eol=lf
LICENSE text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.pkl binary
*.h5 binary
*.joblib binary
*.sav binary
*.npy binary
*.npz binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Diff settings for specific files
*.ipynb diff=jupyternotebook
*.py diff=python
